<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- High score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="BEST"
                android:textSize="10sp"
                android:textColor="#AACCFF"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvHighScore"
                android:text="BEST 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Current score (center, large) -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:fontFamily="sans-serif-black"/>

        <!-- Restart button -->
        <ImageButton
            android:id="@+id/btnRestart"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/btn_circle_bg"
            android:tint="#FFFFFF"
            android:contentDescription="Restart"
            android:padding="10dp"/>

    </LinearLayout>

    <!-- ── Combo label (animated, overlaid) ── -->
    <TextView
        android:id="@+id/tvCombo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COMBO ×2"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD600"
        android:visibility="invisible"
        android:elevation="8dp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Game board ── -->
    <com.blockpuzzle.ui.GameBoardView
        android:id="@+id/boardView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/trayView"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="4dp"/>

    <!-- ── Tray (3 pieces) ── -->
    <com.blockpuzzle.ui.TrayView
        android:id="@+id/trayView"
        android:layout_width="0dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="8dp"/>

    <!-- ── Game Over overlay ── -->
    <FrameLayout
        android:id="@+id/gameOverLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#CC000B1E"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_bg"
            android:padding="32dp">

            <TextView
                android:text="GAME OVER"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvFinalScore"
                android:text="Score: 0"
                android:textSize="20sp"
                android:textColor="#AACCFF"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnPlayAgain"
                android:text="PLAY AGAIN"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#448AFF"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="32dp"
                android:layout_width="wrap_content"
                android:layout_height="48dp"/>
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
